### Tenshi compatible keys (fill in real values)
# Claude
CLAUDE_API_KEY=
# Gemini
GEMINI_API_KEY=
# Grok
GROK_API_KEY=
# Web search (preferred)
TAVILY_KEY=

### Server
HOST=127.0.0.1
PORT=8000

### RAG
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5

### Web search
WEB_SEARCH_MAX_RESULTS=5

### Models
# One model used as default (UI also allows choosing any supported one)
# Claude: claude-opus-4-6-thinking / claude-opus-4-6 / claude-3-5-sonnet-20241022 / claude-3-opus-20240229
# Gemini: gemini-3.1-pro-preview / gemini-2.5-pro / gemini-3-flash-preview / gemini-2.5-flash
# Grok: grok-4-1-fast-non-reasoning / grok-4-1-fast-reasoning
DEFAULT_CHAT_MODEL=claude-3-5-sonnet-20241022

### Optional Claude proxies (same env var names as Tenshi; leave empty to disable)
CLAUDE_PROXY_KEY=
CLAUDE_PROXY_BASE_URL=
CLAUDE_PROXY_KEY_2=
CLAUDE_PROXY_BASE_URL_2=
