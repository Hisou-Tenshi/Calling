### Tenshi compatible keys (fill in real values)
# Claude
CLAUDE_API_KEY=
# Gemini
GEMINI_API_KEY=
# Grok
GROK_API_KEY=
# Web search (preferred)
TAVILY_KEY=

### Server
HOST=127.0.0.1
PORT=8000

### RAG
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5

### Web search
WEB_SEARCH_MAX_RESULTS=5

### Models
# One model used as default (UI also allows choosing any supported one)
# Claude: claude-opus-4-6-thinking / claude-opus-4-6 / claude-3-5-sonnet-20241022 / claude-3-opus-20240229
# Gemini: gemini-3.1-pro-preview / gemini-2.5-pro / gemini-3-flash-preview / gemini-2.5-flash
# Grok: grok-4-1-fast-non-reasoning / grok-4-1-fast-reasoning
DEFAULT_CHAT_MODEL=glm-4.7-flash

### OpenAI-compatible gateway (for GLM trial and any other compatible models)
# Example providers:
# - Glama Gateway: https://glama.ai/api/gateway/openai/v1
# - OpenRouter:   https://openrouter.ai/api/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=

### Trial model (unauthenticated users are forced to use this model)
CALLING_TRIAL_MODEL=glm-4.7-flash

### Global trial quota (shared across everyone)
# Total allowed trial chat requests per hour (best-effort without Redis; exact with Upstash).
CALLING_TRIAL_GLOBAL_PER_HOUR=10

### Optional Claude proxies (same env var names as Tenshi; leave empty to disable)
CLAUDE_PROXY_KEY=
CLAUDE_PROXY_BASE_URL=
CLAUDE_PROXY_KEY_2=
CLAUDE_PROXY_BASE_URL_2=

### Auth / Anti-abuse
# Modes: none | apikey | password | github
CALLING_AUTH_MODE=none
CALLING_AUTH_SECRET=

# Optional: allow x-api-key header to bypass session (useful for scripts)
CALLING_API_KEY=

# Password login (if CALLING_AUTH_MODE=password)
CALLING_PASSWORD=

# GitHub OAuth (if CALLING_AUTH_MODE=github)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# IMPORTANT: at least one allow-list must be set, otherwise login is denied by default.
GITHUB_ALLOWED_USERS=your_github_login
GITHUB_ALLOWED_ORGS=

### Rate limit
# Per-minute limits. For serverless, in-memory limiter resets on cold start;
# use Upstash below for stable limits.
CALLING_RL_IP_PER_MIN=60
CALLING_RL_USER_PER_MIN=120

# Optional: Upstash Redis (recommended on Vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
